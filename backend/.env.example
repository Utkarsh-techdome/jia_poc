# Get your API key from https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# LLM model to use via OpenRouter
# Fast options for sub-1s latency:
#   - meta-llama/llama-3.3-70b-instruct (good balance)
#   - google/gemini-2.0-flash-exp:free (very fast TTFT)
#   - qwen/qwen-2.5-72b-instruct (capable, fast)
#   - meta-llama/llama-3.1-8b-instruct (fastest, less capable)
LLM_MODEL=meta-llama/llama-3.3-70b-instruct

# STT model size: tiny, base, small, medium, large-v3
# 'small' is the recommended balance for CPU (~300ms)
# Use 'tiny' for fastest, 'base' for balance
WHISPER_MODEL=tiny

# Whisper device: cpu or cuda
WHISPER_DEVICE=cpu

# Whisper compute type: int8 (CPU), float16 (GPU), int8_float16 (GPU)
WHISPER_COMPUTE_TYPE=int8

# Kokoro voice options:
#   Female: af_heart, af_bella, af_nicole, af_sarah
#   Male: am_michael, am_adam, am_echo
KOKORO_VOICE=af_heart

# Server config
HOST=0.0.0.0
PORT=8000
